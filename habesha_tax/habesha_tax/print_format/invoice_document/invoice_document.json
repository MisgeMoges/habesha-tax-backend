 "html": "<style>\n    @media print {\n        .page-break {\n            page-break-after: always;\n        }\n    }\n\n    body {\n        font-family: Arial, sans-serif;\n        font-size: 13px;\n        color: #000;\n    }\n\n    .invoice-box {\n        width: 100%;\n        padding: 40px;\n        border: 1px solid #000;\n        position: relative;\n    }\n\n    /* Header layout for title and logo */\n    .header {\n        display: flex;\n        justify-content: space-between;\n        align-items: flex-start;\n        margin-bottom: 20px;\n    }\n\n    .logo img {\n        max-height: 90px;\n    }\n\n    h2 {\n        color: #3b6ea5;\n        margin-bottom: 10px;\n    }\n\n    .section-title {\n        color: #3b6ea5;\n        font-weight: bold;\n        margin-top: 20px;\n        margin-bottom: 5px;\n    }\n\n    table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 10px;\n    }\n\n    table, th, td {\n        border: 1px solid #000;\n    }\n\n    th, td {\n        padding: 6px;\n    }\n\n    .right {\n        text-align: right;\n    }\n\n    .no-border td {\n        border: none;\n    }\n</style>\n\n<div class=\"invoice-box\">\n\n    <!-- Header with Invoice Title and Logo -->\n    <div class=\"header\">\n        <div>\n            <h2>INVOICE</h2>\n        </div>\n\n        <div class=\"logo\">\n            <img src=\"{{ doc.company_logo }}\">\n        </div>\n    </div>\n\n    <p><strong>Company Name:</strong> {{ doc.company_name }}</p>\n    <p><strong>Address:</strong> {{ doc.address }}</p>\n    <p><strong>Phone:</strong> {{ doc.phone }}</p>\n    <p><strong>Email:</strong> {{ doc.email }}</p>\n    <p><strong>CRN:</strong> {{ doc.company_registration_number }}</p>\n    <p><strong>VAT Number:</strong> {{ doc.vat_number }}</p>\n\n    <div class=\"section-title\">Bill To:</div>\n\n    <p><strong>Client Company:</strong> {{ doc.to_company_name }}</p>\n    <p><strong>Client Address:</strong> {{ doc.to_address }}</p>\n    <p><strong>Phone:</strong> {{ doc.to_phone }}</p>\n\n    <!-- Invoice Number & Dates from Child Table -->\n    <table>\n        {% for row in doc.invoice_date %}\n        <tr>\n            <td><strong>{{ row.name1 }}</strong></td>\n            <td>{{ row.value }}</td>\n        </tr>\n        {% endfor %}\n    </table>\n\n    <div class=\"section-title\">Description of Services</div>\n\n    <table>\n        <thead>\n            <tr>\n                <th>Item/Service</th>\n                <th>Description</th>\n                <th>Qty</th>\n                <th>Time</th>\n                <th>Rate</th>\n                <th class=\"right\">Amount</th>\n            </tr>\n        </thead>\n        <tbody>\n\n        {% set ns = namespace(subtotal=0) %}\n\n        {% for item in doc.service_details %}\n        \n            {% set row_total = item.total_amount or 0 %}\n            {% set ns.subtotal = ns.subtotal + row_total %}\n        \n            <tr>\n                <td>{{ item.item }}</td>\n                <td>{{ item.description }}</td>\n                <td>{{ item.quantity }}</td>\n                <td>{{ item.time }}</td>\n                <td>{{ item.rate }}</td>\n                <td class=\"right\">{{ row_total }}</td>\n            </tr>\n        \n        {% endfor %}\n\n            <tr>\n                <td colspan=\"4\"></td>\n                <td><strong>Subtotal</strong></td>\n                <td class=\"right\"><strong>{{ ns.subtotal }}</strong></td>\n            </tr>\n\n            <tr>\n                <td colspan=\"4\"></td>\n                <td><strong>VAT (0%)</strong></td>\n                <td class=\"right\">0.00</td>\n            </tr>\n\n            <tr>\n                <td colspan=\"4\"></td>\n                <td><strong>Total</strong></td>\n                <td class=\"right\"><strong>{{ ns.subtotal }}</strong></td>\n            </tr>\n\n        </tbody>\n    </table>\n\n    <div class=\"page-break\"></div>\n\n    <div class=\"section-title\">Payment Instructions</div>\n\n    <p><strong>Bank Name:</strong> {{ doc.bank_name }}</p>\n    <p><strong>Account Name:</strong> {{ doc.account_name }}</p>\n    <p><strong>Account Number:</strong> {{ doc.account_number }}</p>\n    <p><strong>Sort Code:</strong> {{ doc.sort_code }}</p>\n    <p><strong>Pay via Email:</strong> {{ doc.payment_email }}</p>\n    <p><strong>Reference:</strong> Invoice {{ doc.name }}</p>\n\n    <div class=\"section-title\">Notes</div>\n\n    <p>\n        Thank you for your business! Please make payment by the due date.\n    </p>\n\n</div>",
